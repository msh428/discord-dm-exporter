{
  "manifest_version": 3,
  "name": "Discord DM Exporter",
  "version": "1.1.0",
  "description": "Discord DM 대화를 HTML, JSON, CSV, TXT로 내보내기",
  "permissions": ["storage", "downloads", "tabs", "scripting"],
  "host_permissions": [
    "https://discord.com/*",
    "https://cdn.discordapp.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://discord.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://discord.com/*"],
      "js": ["injected.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
